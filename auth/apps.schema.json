{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/modeled-information-format/.github/auth/apps.schema.json",
  "title": "MIF org GitHub-App auth manifest",
  "description": "Validates auth/apps.json — the five least-privilege GitHub Apps and how workflows mint their tokens.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "mint_action", "identifier", "apps"],
  "properties": {
    "$schema": { "type": "string" },
    "description": { "type": "string" },
    "version": { "type": "integer", "const": 1 },
    "mint_action": {
      "type": "string",
      "description": "The token-minting action, SHA-pinned (40-char) with a version comment.",
      "pattern": "^actions/create-github-app-token@[0-9a-f]{40}$"
    },
    "identifier": {
      "type": "string",
      "const": "client-id",
      "description": "Apps are identified by OAuth client-id, not the deprecated app-id."
    },
    "apps": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/app" }
    }
  },
  "$defs": {
    "app": {
      "type": "object",
      "additionalProperties": false,
      "required": ["purpose", "id_variable", "key_secret", "permissions", "install_on", "consumers"],
      "properties": {
        "purpose": { "type": "string", "minLength": 1 },
        "id_variable": {
          "type": "string",
          "description": "Org variable holding the App OAuth client-id. Must be <ROLE>_CLIENT_APP_ID.",
          "pattern": "^[A-Z][A-Z0-9]*_CLIENT_APP_ID$"
        },
        "key_secret": {
          "type": "string",
          "description": "Org secret holding the App private key. Must be <ROLE>_CLIENT_APP_PRIVATE_KEY.",
          "pattern": "^[A-Z][A-Z0-9]*_CLIENT_APP_PRIVATE_KEY$"
        },
        "permissions": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "enum": ["read", "write"]
          }
        },
        "install_on": {
          "description": "Repos the App is installed on. \"all\" means every org repo (org-wide install); an array names a specific subset.",
          "oneOf": [
            { "const": "all" },
            {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            }
          ]
        },
        "consumers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "description": "Repo-qualified workflow path (<repo>/.github/workflows/...) that mints this App's token.",
            "pattern": "^[^/]+/\\.github/workflows/[^/]+\\.ya?ml$"
          },
          "uniqueItems": true
        }
      }
    }
  }
}
